# Public dashboard reads
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Optional, used for OAuth redirect allow-list documentation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side imports and admin routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared secret for the v1 admin import screen
ADMIN_IMPORT_SECRET=choose-a-shared-secret

# Optional chat / OpenAI-compatible provider settings
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
ENABLE_TOPIC_CACHE_LLM_MERGE=true
ENABLE_TOPIC_CACHE_LLM_SECONDARY=true
TOPIC_CACHE_LLM_PRIMARY_MODEL=google/gemini-2.5-flash-lite
TOPIC_CACHE_LLM_SECONDARY_MODEL=openai/gpt-4o
MODEL_GATEWAY=openrouter
MODEL_POLICY_PRESET=conservative
MODEL_TASK_VISION_OCR=openai/gpt-4o-mini
MODEL_TASK_VISION_OCR_FALLBACK=google/gemini-2.5-flash
MODEL_TASK_SEGMENTATION=openai/gpt-4.1-mini
MODEL_TASK_SEGMENTATION_FALLBACK=google/gemini-2.5-flash
MODEL_TASK_TRANSLATION=openai/gpt-4.1-mini
MODEL_TASK_TRANSLATION_FALLBACK=google/gemini-2.5-flash
MODEL_TASK_METADATA=google/gemini-2.5-flash-lite
MODEL_TASK_METADATA_FALLBACK=openai/gpt-4.1-nano
MODEL_TASK_KEYWORD_EXTRACTION=openai/gpt-4.1-mini
MODEL_TASK_KEYWORD_EXTRACTION_FALLBACK=google/gemini-2.5-flash
MODEL_TASK_KEYWORD_GROUPING=openai/gpt-4.1-mini
MODEL_TASK_KEYWORD_GROUPING_FALLBACK=google/gemini-2.5-flash
MODEL_TASK_TOPIC_LABELING=openai/gpt-4.1-mini
MODEL_TASK_TOPIC_LABELING_FALLBACK=google/gemini-2.5-flash
MODEL_TASK_TRACK_CLASSIFICATION=google/gemini-2.5-flash-lite
MODEL_TASK_TRACK_CLASSIFICATION_FALLBACK=openai/gpt-4.1-nano
MODEL_TASK_FACET_EXTRACTION=openai/gpt-4.1-mini
MODEL_TASK_FACET_EXTRACTION_FALLBACK=google/gemini-2.5-flash-lite
MODEL_TASK_QUERY_EXPANSION=google/gemini-2.5-flash-lite
MODEL_TASK_QUERY_EXPANSION_FALLBACK=openai/gpt-4.1-nano
MODEL_TASK_CHAT_SYNTHESIS=google/gemini-2.5-flash
MODEL_TASK_CHAT_SYNTHESIS_FALLBACK=openai/gpt-4.1-mini
MODEL_TASK_VISUALIZATION_PLANNING=google/gemini-2.5-flash
MODEL_TASK_VISUALIZATION_PLANNING_FALLBACK=openai/gpt-4.1-mini
ENABLE_CHAT_TOOL_CALLING=false
CHAT_TOOL_MAX_STEPS=3

# Optional Google Drive connector settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/integrations/google-drive/callback
GOOGLE_PICKER_API_KEY=your-google-picker-api-key

# Optional worker logging / polling
WORKER_LOG_LEVEL=INFO
WORKER_POLL_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_INTERVAL_SECONDS=30
WORKER_STALE_PROCESSING_AFTER_SECONDS=1800
WORKER_STALE_PROCESSING_LIMIT=10
WORKER_MAX_RECOVERY_ATTEMPTS=2
WORKER_INVALID_SUCCESS_SCAN_LIMIT=25

# Optional automatic queue processing between Vercel Cron and the Python worker service
CRON_SECRET=choose-a-long-random-secret
WORKER_WEBHOOK_SECRET=choose-a-long-random-secret
WORKER_SERVICE_URL=http://127.0.0.1:8001
