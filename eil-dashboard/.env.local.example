# Public dashboard reads
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Optional, used for OAuth redirect allow-list documentation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-side imports and admin routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared secret for the v1 admin import screen
ADMIN_IMPORT_SECRET=choose-a-shared-secret

# Optional chat / OpenAI-compatible provider settings
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional Google Drive connector settings
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/integrations/google-drive/callback
GOOGLE_PICKER_API_KEY=your-google-picker-api-key
